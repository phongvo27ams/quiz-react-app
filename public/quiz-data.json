                "id": "o-1782401649478-0",
                "questionId": "ep-q3",
                "label": "A",
                "text": "Use only one customer type"
              },
              {
                "id": "o-1782401649478-1",
                "questionId": "ep-q3",
                "label": "B",
                "text": "Split by age only"
